{
  "manifest_version": 3,
  "name": "Bookmarks Sync 书签同步",
  "version": "0.0.1",
  "description": "多端同步书签",
  "permissions": [
    "bookmarks",
    "storage",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://gitee.com/api/v5/*"
  ],
  "background": {
    "service_worker": "back.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings-modal.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
